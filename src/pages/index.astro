---
import Layout from '@layouts/Layout.astro'
import Messages from '@components/messages/Messages.astro'
import CodeSimulation from '@components/CodeSimulation.astro'

const user = Astro.locals.user
const LINK_INSCRIPTION = user ? '/dashboard' : '/login'
---

<Layout showAside={false}>
  <canvas id="page-canvas" class="page__canvas" aria-hidden="true"></canvas>

  <div class="landing">
    <header class="hero">
      <div class="hero__glow"></div>
      <h1 class="hero__title">
        <span class="hero__highlight hero__highlight--a animate-pop-in">A</span
        >cademia
        <span class="hero__highlight hero__highlight--j animate-pop-in">J</span
        >uvenil de <br />
        Programación
        <span class="hero__highlight hero__highlight--c animate-pop-in">C</span
        >ompetitiva
      </h1>

      <h2 class="hero__subtitle animate-fade-in-up">
        <span class="text-gradient">Inscripciones 2026 abiertas</span> 🚀
      </h2>

      <div class="hero__actions animate-fade-in-up">
        <a
          href={LINK_INSCRIPTION}
          class="button-inscription button-inscription--large pulse"
        >
          Inscríbete ahora
        </a>
      </div>

      <div class="hero__messages-wrapper animate-fade-in">
        <Messages />
      </div>

      <p class="hero__badge float-anim animate-fade-in-up">
        <span class="hero__badge-icon">⏳</span>
        Inscripciones abiertas hasta el<strong> 16 de abril</strong>
      </p>
    </header>

    <CodeSimulation />

    <section class="modules reveal">
      <h2 class="modules__title">
        <span class="text-gradient">Nuestras Modalidades</span>
      </h2>
      <div class="modules__grid">
        <article class="module-card reveal-item">
          <div class="module-card__header">
            <span class="module-card__icon">🧠</span>
            <h3 class="module-card__name">Módulo Formativo</h3>
          </div>
          <p class="module-card__description">
            Si nunca has programado o tienes conocimientos básicos, este es tu
            lugar. Partimos desde 0 y avanzamos progresivamente hasta un nivel
            intermedio.
          </p>
        </article>

        <article class="module-card reveal-item">
          <div class="module-card__header">
            <span class="module-card__icon">🏆</span>
            <h3 class="module-card__name">Módulo Competitivo</h3>
          </div>
          <p class="module-card__description">
            Si ya tienes base en programación, aquí es donde llevas todo al
            siguiente nivel. Profundizamos en algoritmos y técnicas clave de
            programación competitiva.
          </p>
        </article>
      </div>
    </section>

    <section class="features reveal">
      <h2 class="features__title">
        <span class="text-gradient">¿Qué incluye el programa?</span>
      </h2>
      <div class="features__grid">
        <div class="feature-item reveal-item">
          <span class="feature-item__icon">📚</span>
          <p class="feature-item__name">Clases guiadas</p>
        </div>
        <div class="feature-item reveal-item">
          <span class="feature-item__icon">🏆</span>
          <p class="feature-item__name">Contest semanal</p>
        </div>
        <div class="feature-item reveal-item">
          <span class="feature-item__icon">📊</span>
          <p class="feature-item__name">Ranking AJPC</p>
        </div>
        <div class="feature-item reveal-item">
          <span class="feature-item__icon">🌱</span>
          <p class="feature-item__name">Mentorías personalizadas</p>
        </div>
        <div class="feature-item reveal-item">
          <span class="feature-item__icon">🤝</span>
          <p class="feature-item__name">Comunidad</p>
        </div>
      </div>
    </section>

    <section class="inscription-banner reveal">
      <div class="inscription-banner__container">
        <h2 class="inscription-banner__title">¿Todo listo para el 2026? 🚀</h2>
        <p class="inscription-banner__text">
          Empieza desde 0 (o no) y llega tan lejos como quieras. Cupos
          limitados.
        </p>
        <a
          href={LINK_INSCRIPTION}
          class="button-inscription button-inscription--large inscription-banner__button glow"
        >
          Inscríbete ahora
        </a>
      </div>
    </section>
  </div>

  <script>
    const observerOptions = {
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px',
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal--visible')
        } else {
          entry.target.classList.remove('reveal--visible')
        }
      })
    }, observerOptions)

    document
      .querySelectorAll('.reveal, .reveal-item')
      .forEach((item) => observer.observe(item))

    const canvas = document.getElementById(
      'page-canvas',
    ) as HTMLCanvasElement | null
    if (canvas) {
      const context = canvas.getContext('2d')

      if (context) {
        let width: number
        let height: number
        let brandPrimaryStr = '#116bb1'
        const symbols = [
          '{ }',
          '[ ]',
          '++',
          ';',
          '&&',
          '->',
          'cin',
          'cout',
          'vector',
          'std::',
          'dp',
          'gcd',
          'while',
          'if',
          '{}',
          '()',
          'main',
          '#include',
          'int',
          'long',
          'struct',
        ]
        const particles: Particle[] = []
        const particleCount = 80

        class Particle {
          x: number = 0
          y: number = 0
          text: string = ''
          size: number = 0
          speedX: number = 0
          speedY: number = 0
          opacity: number = 0
          rotation: number = 0
          rotationSpeed: number = 0

          constructor() {
            this.init()
          }

          init() {
            this.x = Math.random() * width
            this.y = Math.random() * height
            this.text = symbols[Math.floor(Math.random() * symbols.length)]
            this.size = Math.random() * 14 + 12
            this.speedX = Math.random() * 0.5 - 0.25
            this.speedY = Math.random() * 0.5 - 0.25
            this.opacity = Math.random() * 0.15 + 0.08
            this.rotation = Math.random() * Math.PI * 2
            this.rotationSpeed = Math.random() * 0.012 - 0.006
          }

          draw() {
            context.save()
            context.translate(this.x, this.y)
            context.rotate(this.rotation)
            context.font = `bold ${this.size}px "Courier New", Courier, monospace`
            context.globalAlpha = this.opacity
            context.fillStyle = brandPrimaryStr
            context.fillText(this.text, 0, 0)
            context.restore()
          }

          update() {
            this.x += this.speedX
            this.y += this.speedY
            this.rotation += this.rotationSpeed

            if (this.x < -100) this.x = width + 100
            if (this.x > width + 100) this.x = -100
            if (this.y < -100) this.y = height + 100
            if (this.y > height + 100) this.y = -100
          }
        }

        function resize() {
          width = canvas.width = window.innerWidth
          brandPrimaryStr =
            getComputedStyle(document.documentElement)
              .getPropertyValue('--brand-primary')
              .trim() || '#116bb1'
          height = canvas.height = window.innerHeight
          particles.length = 0
          for (let i = 0; i < particleCount; i++) {
            particles.push(new Particle())
          }
        }

        function animate() {
          if (context) {
            context.clearRect(0, 0, width, height)
            particles.forEach((particle) => {
              particle.update()
              particle.draw()
            })
          }
          requestAnimationFrame(animate)
        }

        window.addEventListener('resize', resize)
        resize()
        animate()
      }
    }
  </script>

  <style>
    .landing {
      display: flex;
      flex-direction: column;
      max-width: 75rem;
      margin-left: auto;
      margin-right: auto;
      position: relative;
      min-width: 0;
    }

    @media screen and (min-width: 48rem) {
      .landing {
        gap: 5rem;
      }
    }

    .page__canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      pointer-events: none;
      z-index: -1;
    }

    .hero {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 10;
      min-height: 90dvh;
    }

    .hero__glow {
      position: absolute;
      width: 100%;
      max-width: 50rem;
      aspect-ratio: 1;
      height: auto;
      max-height: 50rem;
      background: radial-gradient(
        circle,
        color-mix(in srgb, var(--brand-primary) 15%, transparent) 0%,
        color-mix(in srgb, var(--brand-secondary) 10%, transparent) 40%,
        color-mix(in srgb, var(--brand-tertiary) 5%, transparent) 60%,
        transparent 80%
      );
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: -1;
      pointer-events: none;
      filter: blur(3.75rem);
      animation: pulse-glow 8s infinite alternate ease-in-out;
    }

    .hero__title,
    .hero__subtitle {
      font-size: clamp(1.5rem, 7vw, 4.5rem);
      line-height: 1.05;
      margin: 0;
      color: var(--text-color-primary);
      max-width: 56.25rem;
      letter-spacing: -0.02em;
      margin-bottom: 0;
    }

    .hero__subtitle {
      font-size: clamp(1.5rem, 3vw, 3.5rem);
      margin-top: 3rem;
      margin-bottom: 3rem;
      font-weight: 800;
    }

    .hero__highlight {
      display: inline-block;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .hero__highlight:hover {
      transform: translateY(-0.5rem) scale(1.1);
    }

    .hero__highlight--a {
      color: var(--brand-primary);
    }
    .hero__highlight--j {
      color: var(--brand-secondary);
    }
    .hero__highlight--c {
      color: var(--brand-tertiary);
    }

    .text-gradient {
      background: linear-gradient(
        to right,
        var(--brand-primary),
        var(--brand-secondary),
        var(--brand-tertiary),
        var(--brand-primary)
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shine 4s linear infinite;
    }

    .hero__ticker {
      width: 100%;
      border-top: 0.0625rem solid var(--border-color);
      border-bottom: 0.0625rem solid var(--border-color);
      padding: 1rem 0;
      background-color: var(--border-color-light);
      margin: 2rem 0;
    }

    .hero__enrollment {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .hero__badge {
      padding: 0.75rem 2rem;
      background: var(--foreground-color);
      margin-top: 2rem;
      margin-bottom: 0;
      border: 0.15rem solid var(--border-color);
      border-radius: 10rem;
      box-shadow: var(--shadow);
      font-size: 1.15rem;
      color: var(--text-color-secondary);
      font-weight: 500;
    }

    .hero__badge-icon {
      font-size: 1.25rem;
    }

    .reveal {
      opacity: 0.1;
      transform: translateY(1.25rem);
      transition:
        opacity 0.8s ease,
        transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .reveal--visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-item {
      opacity: 0.1;
      transform: translateY(0.9375rem);
      transition:
        opacity 0.6s ease,
        transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
      transition-delay: calc(var(--order) * 0.1s);
    }

    .reveal--visible.reveal-item {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes popIn {
      0% {
        transform: scale(0.8);
        opacity: 0;
      }
      100% {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes fadeInUp {
      0% {
        transform: translateY(1.25rem);
        opacity: 0;
      }
      100% {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @keyframes fadeIn {
      0% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }

    @keyframes pulse-glow {
      0% {
        transform: translate(-50%, -50%) scale(0.9);
        opacity: 0.7;
      }
      100% {
        transform: translate(-50%, -50%) scale(1.1);
        opacity: 1;
      }
    }

    @keyframes shine {
      to {
        background-position: 200% center;
      }
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(-1.25rem) rotate(5deg);
      }
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0
          color-mix(in srgb, var(--brand-primary) 40%, transparent);
      }
      70% {
        box-shadow: 0 0 0 0.625rem
          color-mix(in srgb, var(--brand-primary) 0%, transparent);
      }
      100% {
        box-shadow: 0 0 0 0
          color-mix(in srgb, var(--brand-primary) 0%, transparent);
      }
    }

    @keyframes glow {
      0%,
      100% {
        box-shadow: 0 0.625rem 1.875rem
          color-mix(in srgb, var(--brand-primary) 20%, transparent);
      }
      50% {
        box-shadow: 0 0.9375rem 2.5rem
          color-mix(in srgb, var(--brand-primary) 40%, transparent);
      }
    }

    .animate-pop-in {
      animation: popIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
    }
    .animate-fade-in-up {
      animation: fadeInUp 0.8s ease-out both;
    }
    .animate-fade-in {
      animation: fadeIn 1s ease-out both;
    }
    .float-anim {
      animation: float 6s infinite ease-in-out;
    }
    .pulse {
      animation: pulse 2s infinite;
    }
    .glow {
      animation: glow 4s infinite ease-in-out;
    }

    /* Staggered Animations */
    .hero__actions {
      animation-delay: 0.2s;
    }
    .hero__messages-wrapper {
      animation-delay: 0.4s;
    }
    .hero__badge {
      animation-delay: 0.6s;
    }

    .reveal-item:nth-child(1) {
      transition-delay: 0.1s;
    }
    .reveal-item:nth-child(2) {
      transition-delay: 0.2s;
    }
    .reveal-item:nth-child(3) {
      transition-delay: 0.3s;
    }
    .reveal-item:nth-child(4) {
      transition-delay: 0.4s;
    }
    .reveal-item:nth-child(5) {
      transition-delay: 0.5s;
    }
    .reveal-item:nth-child(6) {
      transition-delay: 0.6s;
    }

    .hero__highlight--a {
      animation-delay: 0.1s;
    }
    .hero__highlight--j {
      animation-delay: 0.2s;
    }
    .hero__highlight--c {
      animation-delay: 0.3s;
    }

    .button-inscription {
      display: inline-block;
      padding: 1rem 2.75rem;
      background-color: var(--brand-primary);
      color: var(--button-primary-color);
      border-radius: 6.25rem;
      font-size: 1.15rem;
      text-decoration: none;
      transition:
        transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275),
        background-color 0.2s,
        box-shadow 0.2s;
      box-shadow: 0 0.25rem 0.75rem
        color-mix(in srgb, var(--brand-primary) 20%, transparent);
      font-weight: 700;
    }

    .button-inscription:hover {
      background-color: var(--brand-secondary);
      transform: translateY(-0.25rem) scale(1.02);
      box-shadow: 0 0.5rem 1.5rem
        color-mix(in srgb, var(--brand-secondary) 30%, transparent);
    }

    .button-inscription--large {
      padding: 1.25rem 4rem;
      font-size: 1.35rem;
    }
    .modules {
    }

    .modules__title {
      font-size: 2.5rem;
      margin-bottom: 4rem;
      text-align: start;
      font-weight: 850;
    }

    .modules__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    @media screen and (min-width: 48rem) {
      .modules__grid {
        grid-template-columns: 1fr 1fr;
        text-align: start;
      }
    }

    .module-card {
      padding: 2.5rem;
      background: color-mix(in srgb, var(--foreground-color) 65%, transparent);
      backdrop-filter: blur(1rem);
      -webkit-backdrop-filter: blur(1rem);
      border-radius: 2rem;
      border: 0.0625rem solid var(--border-color);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .module-card:hover {
      transform: translateY(-0.625rem) scale(1.02);
      border-color: var(--brand-primary);
      box-shadow: 0 0.9375rem 2.5rem
        color-mix(in srgb, var(--brand-primary) 15%, transparent);
    }

    .module-card__header {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .module-card__icon {
      font-size: 2rem;
    }

    .module-card__name {
      font-size: clamp(1.25rem, 2vw, 1.75rem);
      margin: 0;
      color: var(--brand-primary);
      font-weight: 800;
    }

    .module-card__description {
      color: var(--text-color-secondary);
      line-height: 1.7;
      margin: 0;
      font-size: 1.05rem;
    }

    .modules__note {
      text-align: center;
      color: var(--text-color-secondary);
      font-weight: 500;
    }

    .features {
      margin-bottom: 3rem;
      text-align: center;
    }

    .features__title {
      font-size: 2.5rem;
      margin-bottom: 3rem;
      font-weight: 850;
    }

    .features__grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem;
    }

    .feature-item {
      padding: 2rem 1.5rem;
      background: color-mix(in srgb, var(--foreground-color) 65%, transparent);
      backdrop-filter: blur(1rem);
      -webkit-backdrop-filter: blur(1rem);
      border-radius: 1.5rem;
      border: 0.0625rem solid var(--border-color);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      width: 100%;
    }

    @media screen and (min-width: 30rem) {
      .feature-item {
        width: 12rem;
      }
    }

    .feature-item:hover {
      transform: translateY(-0.625rem) scale(1.05);
      border-color: var(--brand-secondary);
      box-shadow: 0 0.9375rem 2.5rem
        color-mix(in srgb, var(--brand-secondary) 15%, transparent);
    }

    .feature-item__icon {
      font-size: 3.5rem;
    }

    .feature-item__name {
      margin: 0;
      font-size: 1.15rem;
      font-weight: 700;
    }

    .inscription-banner {
      padding: 5rem 0;
    }

    .inscription-banner__container {
      background: linear-gradient(
        135deg,
        var(--brand-primary),
        var(--brand-secondary)
      );
      color: var(--button-primary-color);
      padding: 5rem 2rem;
      border-radius: 3rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      box-shadow: 0 1.25rem 3.125rem
        color-mix(in srgb, var(--brand-primary) 30%, transparent);
    }

    .inscription-banner__title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin: 0;
      color: var(--button-primary-color);
      font-weight: 900;
    }

    .inscription-banner__text {
      font-size: 1.3rem;
      opacity: 0.95;
      margin: 0;
      max-width: 60ch;
    }

    .inscription-banner__button {
      background-color: var(--button-primary-color);
      color: var(--brand-primary);
      box-shadow: 0 0.625rem 1.875rem rgba(0, 0, 0, 0.2);
    }

    .inscription-banner__button:hover {
      background-color: var(--button-primary-color);
      transform: translateY(-0.5rem) scale(1.05);
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal,
      .reveal-item,
      .animate-pop-in,
      .animate-fade-in-up,
      .float-anim,
      .pulse,
      .glow {
        animation: none;
        transition: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>
</Layout>
