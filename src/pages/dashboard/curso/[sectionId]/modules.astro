---
import DashboardLayout from '@layouts/DashboardLayout.astro'
import PanelNavigation from '@components/ui/PanelNavigation.astro'
import SectionModulesView from '@components/dashboard/SectionModulesView.svelte'
import { getSectionData, verifyStudentAccess } from '@lib/sections'
import { db } from '@db/index'
import { modules, moduleMaterials } from '@db/schema'
import { eq } from 'drizzle-orm'

const user = Astro.locals.user!
if (!user) return Astro.redirect('/login')

const { sectionId } = Astro.params

const sectionRow = await getSectionData(sectionId!)

if (!sectionRow) return Astro.redirect('/dashboard')

if (!(await verifyStudentAccess(user, sectionId!)))
  return Astro.redirect('/dashboard')

const rawModules = await db
  .select()
  .from(modules)
  .where(eq(modules.courseId, sectionRow.courseId))
  .orderBy(modules.createdAt)

const initialModules = (await Promise.all(
  rawModules.map(async (module) => {
    const materials = await db
      .select()
      .from(moduleMaterials)
      .where(eq(moduleMaterials.moduleId, module.id))
    return {
      ...module,
      createdAt: module.createdAt?.toISOString() || null,
      updatedAt: module.updatedAt?.toISOString() || null,
      materials: materials.map((material) => ({
        ...material,
        createdAt: material.createdAt?.toISOString() || null,
      })),
    }
  }),
)) as any

const tabs = [
  {
    id: 'modules',
    href: `/dashboard/curso/${sectionId}/modules`,
    label: 'Contenidos',
    icon: '📚',
  },
  {
    id: 'attendance',
    href: `/dashboard/curso/${sectionId}/attendance`,
    label: 'Asistencia',
    icon: '📝',
  },
]
---

<DashboardLayout
  metadata={{
    title: `${sectionRow.name} — Contenidos`,
    description: sectionRow.courseName,
  }}
>
  <PanelNavigation
    title={`${sectionRow.name} · ${sectionRow.courseName}`}
    {tabs}
    activeTab="modules"
    ariaLabel={`Secciones de ${sectionRow.name}`}
  >
    <Fragment slot="meta">
      <a href="/dashboard" data-astro-prefetch class="back-link">← Volver</a>
    </Fragment>
  </PanelNavigation>

  <SectionModulesView
    client:load
    courseId={sectionRow.courseId}
    isAdmin={false}
    initialModules={initialModules}
    readOnly={true}
  />
</DashboardLayout>

<style>
  .back-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-color-secondary);
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--brand-primary);
  }
</style>
