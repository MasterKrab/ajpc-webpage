---
import { isTeacher, isAdmin } from '@lib/auth'
import { getSectionData, verifyTeacherAccess } from '@lib/sections'

const user = Astro.locals.user!
if (!isTeacher(user)) return Astro.redirect('/dashboard')

const { sectionId } = Astro.params

// Validate access
const section = await getSectionData(sectionId!)

if (!section) return Astro.redirect('/dashboard/docente')

if (!(await verifyTeacherAccess(user, sectionId!)))
  return Astro.redirect('/dashboard/docente')

return Astro.redirect(`/dashboard/docente/${sectionId}/modules`)
---
