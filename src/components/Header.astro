---
import logoSVG from '@assets/logo.svg?raw'

import Svg from '@cxa/astro-inline-svg'

import Navigation from '@components/Navigation.astro'

const { pathname } = Astro.url

const user = Astro.locals.user
const LINK_DASHBOARD = user ? '/dashboard' : '/login'

const menuItems = [
  { href: '/', label: 'Inicio' },
  { href: '/acerca', label: 'Acerca' },
  { href: '/quienes-somos', label: 'Quiénes somos' },
]
---

<header class="header">
  <div class="header__content">
    <a class="logo" href="/" aria-label="Academía Juvenil de Programación">
      <Svg class="logo__image" raw={logoSVG} width={100} height={50} />
    </a>

    <Navigation>
      <ul class="menu">
        {
          menuItems.map((item) => (
            <li class="menu__item">
              <a
                class:list={[
                  'menu__link',
                  {
                    'menu__link--active':
                      item.href == '/'
                        ? pathname == '/'
                        : pathname.startsWith(item.href),
                  },
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="menu__item menu__item--special">
          <a
            class:list={[
              'menu__link menu__link--dashboard',
              {
                'menu__link--active':
                  pathname.startsWith('/dashboard') ||
                  pathname.startsWith('/login'),
              },
            ]}
            href={LINK_DASHBOARD}
          >
            {user ? 'Dashboard' : 'Iniciar sesión'}
          </a>
        </li>
      </ul>
    </Navigation>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10000;
    padding: 0.5rem 1rem;
    width: 100%;
    color: var(--text-color);
    box-shadow: var(--shadow);
    background-color: var(--foreground-color);
  }

  @media screen and (min-width: 60rem) {
    .header {
      grid-column: span 2;
    }
  }

  .header__content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: var(--page-max-width);
    margin-left: auto;
    margin-right: auto;
  }

  @media screen and (min-width: 60rem) {
    .header__content {
      display: grid;
      grid-template-columns: 100px auto 100px;
      gap: 0;
    }
  }

  .logo {
    position: relative;
    z-index: 1000;
    align-self: end;
  }

  .menu {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    height: 100%;
    font-weight: bold;
    list-style: none;
    margin-top: 0;
    margin-bottom: 0;
    padding-left: 0;
  }

  @media screen and (max-width: 60rem) {
    .menu {
      flex-direction: column;
      gap: 2.5rem;
      font-size: 2rem;
    }
  }

  .menu__item:hover {
    color: var(--menu-item-color, var(--text-color-primary));
  }

  .menu__item:first-child {
    --menu-item-color: var(--brand-primary);
  }

  .menu__item:nth-child(2) {
    --menu-item-color: var(--brand-secondary);
  }

  .menu__item:nth-child(3) {
    --menu-item-color: var(--brand-tertiary);
  }

  .menu__link,
  .menu__link::before,
  .menu__link::after {
    transition: color 0.3s ease-in-out;
    color: var(--menu-item-color, var(--text-color-primary));
  }

  .menu__link::before,
  .menu__link::after {
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .menu__link::before {
    content: '{';
  }

  .menu__link::after {
    content: '}';
  }

  .menu__link--active::before,
  .menu__link--active::after {
    opacity: 1;
  }

  .menu__link:active::before,
  .menu__link:hover::before,
  .menu__link:active::after,
  .menu__link:hover::after {
    opacity: 1;
  }

  .menu__link--dashboard {
    position: relative;
    padding: 0.4rem 1.5rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    background: linear-gradient(
      135deg,
      var(--brand-primary) 0%,
      var(--brand-secondary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 1;
  }

  :root.dark .menu__link--dashboard {
    background: linear-gradient(135deg, #fff 0%, var(--brand-primary) 100%);
    -webkit-background-clip: text;
  }

  .menu__link--dashboard::before,
  .menu__link--dashboard::after {
    display: none !important;
  }

  .menu__link--dashboard:hover {
    transform: scale(1.05);
    filter: brightness(1.2);
  }

  .menu__item--special {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    transition: all 0.3s ease;
    overflow: hidden;
    color: var(--text-color-secondary);
  }

  .menu__item--special::before {
    content: '';
    position: absolute;
    inset: -50%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      var(--brand-primary) 90deg,
      var(--brand-secondary) 180deg,
      var(--brand-tertiary) 270deg,
      transparent 360deg
    );
    animation: rotate-gradient 4s linear infinite;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }

  .menu__item--special:hover::before {
    opacity: 1;
  }

  .menu__item--special::after {
    content: '';
    position: absolute;
    inset: 2px;
    background: var(--foreground-color);
    border-radius: 1.35rem;
    z-index: 0;
  }

  @keyframes rotate-gradient {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media screen and (max-width: 60rem) {
    .menu__item--special {
      width: 100%;
      max-width: 20rem;
      margin-top: 1rem;
    }

    .menu__link--dashboard {
      font-size: 1.5rem;
      padding: 1.2rem 3rem;
    }
  }
</style>
