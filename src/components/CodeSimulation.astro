</div>

<script>
  ;(function initSimulation() {
    let hasAnimated = false
    const rawCodeLines = [
      'string text;',
      '    cin >> text;',
      '',
      '    cout << decrypt(text) << "\\n";',
      '}',
    ]
    const rawCodeToType = rawCodeLines.join('\n')

    const formattedCodeLines = [
      '<span class="kw">string</span> text;',
      '    <span class="fn">cin</span> &gt;&gt; text;',
      '',
      '    <span class="fn">cout</span> &lt;&lt; <span class="fn">decrypt</span>(text) &lt;&lt; <span class="str">"\\n"</span>;',
      '    <span class="kw">return</span> <span class="num">0</span>;',
      '}',
    ]
    const formattedCode = formattedCodeLines.join('\n')
    const termCmdToType = `g++ main.cpp -o main.out && ./main.out < input.txt`

    const ideTarget = document.getElementById('anim-code-target')
    const ideCursor = document.getElementById('ide-cursor')
    const termCmdTarget = document.getElementById('anim-term-cmd')
    const termCursor = document.getElementById('term-cursor')
    const termOutput = document.getElementById('term-output')
    const container = document.querySelector('.code-simulation')

    function startAnimation() {
      if (hasAnimated) return
      hasAnimated = true

      if (
        !ideTarget ||
        !ideCursor ||
        !termCmdTarget ||
        !termCursor ||
        !termOutput
      )
        return

      let i = 0

      const ideInterval = setInterval(() => {
        ideTarget.textContent += rawCodeToType.charAt(i)
        i++
        if (i >= rawCodeToType.length) {
          clearInterval(ideInterval)
          ideTarget.innerHTML = formattedCode
          ideCursor.style.display = 'none'

          setTimeout(() => {
            termCursor.style.display = 'inline'
            let j = 0
            const termInterval = setInterval(() => {
              termCmdTarget.textContent += termCmdToType.charAt(j)
              j++
              if (j >= termCmdToType.length) {
                clearInterval(termInterval)
                termCursor.style.display = 'none'

                setTimeout(() => {
                  termOutput.style.display = 'block'
                }, 100)
              }
            }, 30)
          }, 300)
        }
      }, 10)
    }

    if (container && window.IntersectionObserver) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return

            startAnimation()
            observer.disconnect()
          })
        },
        { threshold: 0.3 },
      )
      observer.observe(container)
    } else {
      // Fallback if no IntersectionObserver
      setTimeout(startAnimation, 1000)
    }
  })()
</script>

