    </div>
    <div class="window__body">
      <pre
        class="code-block"><code><span class="kw">#include</span> <span class="str">&lt;bits/stdc++.h&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">string</span> <span class="fn">decrypt</span>(<span class="kw">string</span> text) {"{"}
    <span class="kw">for</span> (<span class="kw">auto</span> &amp;character : text) character ^= <span class="num">998244353</span>;
    <span class="kw">return</span> text;
}

<span class="kw">int</span> <span class="fn">main</span>() {"{"}
    <span class="fn">ios_base::sync_with_stdio</span>(<span class="num">0</span>); <span class="fn">cin.tie</span>(<span class="num">0</span>);
    
    <span id="anim-code-target" /><span class="cursor" id="ide-cursor">|</span></code></pre>
